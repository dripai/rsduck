<service>
  <id>rsduck</id>
  <name>rsduck</name>
  <description>rsduck in-memory DuckDB middleware service</description>

  <executable>%BASE%\rsduck.exe</executable>
  <workingdirectory>%BASE%</workingdirectory>
  <startmode>Automatic</startmode>
  <stoptimeout>120sec</stoptimeout>
  <preshutdown>true</preshutdown>
  <preshutdownTimeout>120sec</preshutdownTimeout>
  <hidewindow>true</hidewindow>

  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>3</keepFiles>
  </log>

  <onfailure action="restart" delay="10 sec" />
</service>
