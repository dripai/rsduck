<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dripai.rsduck</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Application Support/rsduck/rsduck</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Library/Application Support/rsduck</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>/Library/Application Support/rsduck/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Application Support/rsduck/logs/launchd.err.log</string>
</dict>
</plist>
